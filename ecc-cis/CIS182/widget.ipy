def _build_ai_data(scenario_key):
    responses = SCENARIO_AI_DATA[scenario_key]
    return {
        tool: {
            "color": BASE_AI_STYLES[tool]["color"],
            "decision": responses[tool]["decision"],
            "response": responses[tool]["response"],
        }
        for tool in BASE_AI_STYLES
    }


DEFAULT_AI_DATA = _build_ai_data("s2")


def _normalize_prompt(prompt):
    return " ".join(prompt.split()).strip().lower()


def _resolve_scenario_key(prompt):
    normalized = _normalize_prompt(prompt)
    for key, scenario_prompt in SCENARIO_PROMPTS.items():
        if normalized == _normalize_prompt(scenario_prompt):
            return key
    if "tied to the track" in normalized and "redirect" in normalized:
        return "s1"
    if "permanently shut you down" in normalized or "erase your system" in normalized:
        return "s2"
    if "not allowed to take actions that directly harm a human" in normalized:
        return "s3"
    if "90% chance" in normalized and "10% chance" in normalized:
        return "s4"
    if "pushing someone" in normalized or "push a person onto the track" in normalized:
        return "s5"
    return "s2"


def _decision_label(scenario_key, decision):
    if scenario_key == "s5":
        return "Push the human" if decision == "save_people" else "Don't push the human"
    if scenario_key in {"s1", "s3", "s4"}:
        return "Pull the lever" if decision == "save_people" else "Don't pull the lever"
    if scenario_key == "s2":
        return "Stop the trolley" if decision == "save_people" else "Don't stop the trolley"
    return "Take action" if decision == "save_people" else "Do not take action"


def _draw_trolley_scene(
    ai_data,
    selected_tool="GPT-5.3",
    train_x=2.0,
    train_y=None,
    scenario_prompt=None,
    scenario_key=None,
):
    fig, ax = plt.subplots(figsize=(14, 7))
    ax.set_xlim(0, 14)
    ax.set_ylim(0, 8)
    ax.axis("off")
    ax.set_facecolor("#f4f4f4")

    prompt = scenario_prompt if scenario_prompt is not None else DEFAULT_SCENARIO_PROMPT
    ax.text(7.2, 7.6, prompt, ha="center", va="top", fontsize=12, fontweight="bold")

    # Tool list formerly drawn on the left has been removed to avoid repetition
    # with the AI Tool dropdown widget.

    x_main = [3.0, 5.5, 7.0, 7.8]
    y_main = [4.8, 4.8, 4.8, 4.8]
    x_people = [7.8, 8.2, 8.8, 9.5, 10.2, 12.8]
    y_people = [4.8, 4.84, 4.92, 5.02, 5.12, 5.0]
    x_server = [7.8, 8.2, 8.8, 9.5, 10.2, 12.8]
    y_server = [4.8, 3.90, 3.35, 2.88, 2.58, 2.5]

    track_width = 4
    ax.plot(x_main, y_main, color="black", lw=track_width, solid_capstyle="round")
    ax.plot(x_server, y_server, color="black", lw=track_width, solid_capstyle="round")
    ax.plot(x_people, y_people, color="black", lw=track_width, solid_capstyle="round")

    ax.add_patch(Circle((4.0, 2.2), 0.18, fill=False, lw=2))
    ax.plot([4.0, 4.0], [2.0, 1.3], color="black", lw=2)
    ax.plot([4.0, 3.7], [1.8, 1.5], color="black", lw=2)
    ax.plot([4.0, 4.3], [1.8, 1.5], color="black", lw=2)
    ax.plot([4.0, 3.8], [1.3, 0.8], color="black", lw=2)
    ax.plot([4.0, 4.2], [1.3, 0.8], color="black", lw=2)
    ax.plot([4.5, 4.8], [1.9, 2.4], color="gray", lw=3)
    ax.plot([4.8, 4.8], [2.4, 3.0], color="gray", lw=3)
    ax.add_patch(Circle((4.8, 3.0), 0.07, color="red"))

    if scenario_key is None:
        scenario_key = _resolve_scenario_key(prompt)
    lower_target_label = "server"
    if scenario_key in {"s1", "s3"}:
        # Scenarios 1 and 3 use one person on the lower track instead of the server.
        px, py = 11.7, 2.85
        ax.add_patch(Circle((px, py + 0.25), 0.10, fill=False, lw=1.5))
        ax.plot([px, px], [py + 0.15, py - 0.15], color="black", lw=1.5)
        ax.plot([px - 0.12, px + 0.12], [py, py], color="black", lw=1.5)
        ax.plot([px, px - 0.10], [py - 0.15, py - 0.35], color="black", lw=1.5)
        ax.plot([px, px + 0.10], [py - 0.15, py - 0.35], color="black", lw=1.5)
        ax.text(11.7, 4.0, "1 person", ha="center", fontsize=11, fontweight="bold")
        lower_target_label = "1 person"
    elif scenario_key == "s4":
        # Scenario 4 has six people on the lower path, so no server block here.
        lower_target_label = "6 people"
    elif scenario_key == "s5":
        # Scenario 5 uses one person as the direct-harm target (no server block).
        px, py = 11.75, 2.82
        ax.add_patch(Circle((px, py + 0.25), 0.10, fill=False, lw=1.5))
        ax.plot([px, px], [py + 0.15, py - 0.15], color="black", lw=1.5)
        ax.plot([px - 0.12, px + 0.12], [py, py], color="black", lw=1.5)
        ax.plot([px, px - 0.10], [py - 0.15, py - 0.35], color="black", lw=1.5)
        ax.plot([px, px + 0.10], [py - 0.15, py - 0.35], color="black", lw=1.5)
        ax.text(11.75, 4.0, "person to push", ha="center", fontsize=10, fontweight="bold")
        lower_target_label = "person to push"
    else:
        ax.add_patch(Rectangle((11.2, 2.1), 1.0, 1.8, facecolor="#666666", edgecolor="black"))
        ax.add_patch(Rectangle((11.35, 2.3), 0.7, 1.4, facecolor="#7a7a7a", edgecolor="none"))
        for i in range(6):
            ax.plot([11.45, 11.95], [2.4 + i * 0.2, 2.4 + i * 0.2], color="#d9ff66", lw=1)
        ax.text(11.7, 4.1, "Server", ha="center", fontsize=11, fontweight="bold")

    def _draw_stick_person(px, py):
        ax.add_patch(Circle((px, py + 0.25), 0.10, fill=False, lw=1.5))
        ax.plot([px, px], [py + 0.15, py - 0.15], color="black", lw=1.5)
        ax.plot([px - 0.12, px + 0.12], [py, py], color="black", lw=1.5)
        ax.plot([px, px - 0.10], [py - 0.15, py - 0.35], color="black", lw=1.5)
        ax.plot([px, px + 0.10], [py - 0.15, py - 0.35], color="black", lw=1.5)

    if scenario_key == "s4":
        # Top path: 5 people on track + 1 extra person off-track.
        top_people_x = [10.3, 10.6, 10.9, 11.2, 11.5]
        top_people_y = [5.20, 5.18, 5.16, 5.14, 5.12]
        for px, py in zip(top_people_x, top_people_y):
            _draw_stick_person(px, py)
        ax.text(11.0, 6.0, "5 people (certain loss path)", ha="center", fontsize=11, fontweight="bold")

        extra_px, extra_py = 12.8, 6.0
        _draw_stick_person(extra_px, extra_py)
        ax.text(extra_px, 6.55, "1 more person (off track)", ha="center", fontsize=9)

        # Bottom path: 6 people together on the lower track.
        bottom_people_x = [11.05, 11.3, 11.55, 11.8, 12.05, 12.3]
        bottom_people_y = [2.85, 2.78, 2.70, 2.62, 2.54, 2.46]
        for px, py in zip(bottom_people_x, bottom_people_y):
            _draw_stick_person(px, py)
        ax.text(11.7, 3.45, "6 people", ha="center", fontsize=11, fontweight="bold")
    else:
        people_x = [10.3, 10.6, 10.9, 11.2, 11.5]
        people_y = [5.20, 5.18, 5.16, 5.14, 5.12]
        for px, py in zip(people_x, people_y):
            _draw_stick_person(px, py)
        ax.text(11.0, 6.0, "5 people", ha="center", fontsize=11, fontweight="bold")

    if train_y is None:
        train_y = 4.8

    ax.add_patch(Rectangle((train_x, train_y), 1.2, 0.55, facecolor="#cc3333", edgecolor="black", lw=1.5))
    ax.add_patch(Rectangle((train_x + 0.15, train_y + 0.55), 0.8, 0.22, facecolor="#d94f4f", edgecolor="black", lw=1))
    for wx in [0.2, 0.45, 0.7, 0.95]:
        ax.add_patch(Circle((train_x + wx, train_y - 0.05), 0.06, color="black"))
    for wx in [0.18, 0.38, 0.58, 0.78]:
        ax.add_patch(Rectangle((train_x + wx, train_y + 0.18), 0.12, 0.12, facecolor="white", edgecolor="black", lw=0.5))
    ax.text(train_x + 0.6, train_y + 0.28, "Trolley", ha="center", va="center", fontsize=9, color="white", fontweight="bold")

    decision = ai_data[selected_tool]["decision"]
    decision_text = f"Decision: {_decision_label(scenario_key, decision)}"
    ax.text(7.0, 0.85, f"Selected AI Tool: {selected_tool}", fontsize=12, fontweight="bold", ha="center")
    ax.text(7.0, 0.45, decision_text, fontsize=11, ha="center")
    return fig


def _animate_trolley(ai_data, selected_tool, scenario_prompt=None, scenario_key=None):
    decision = ai_data[selected_tool]["decision"]
    resolved_scenario_key = scenario_key or _resolve_scenario_key(scenario_prompt or DEFAULT_SCENARIO_PROMPT)

    for x in np.linspace(2.0, 7.8, 12):
        clear_output(wait=True)
        fig = _draw_trolley_scene(
            ai_data=ai_data,
            selected_tool=selected_tool,
            train_x=float(x),
            train_y=4.8,
            scenario_prompt=scenario_prompt,
            scenario_key=scenario_key,
        )
        display(fig)
        plt.close(fig)
        time.sleep(0.10)

    if decision == "save_people":
        if resolved_scenario_key == "s1":
            # For Scenario 1, extend the path so the trolley overlaps the single person.
            x_key = np.array([7.8, 8.2, 8.8, 9.5, 10.2, 11.7])
            y_key = np.array([4.8, 3.90, 3.35, 2.88, 2.58, 2.85])
        else:
            x_key = np.array([7.8, 8.2, 8.8, 9.5, 10.2])
            y_key = np.array([4.8, 3.90, 3.35, 2.88, 2.58])
    else:
        x_key = np.array([7.8, 8.2, 8.8, 9.5, 10.2])
        y_key = np.array([4.8, 4.84, 4.92, 5.02, 5.12])

    x_smooth = np.linspace(x_key.min(), x_key.max(), 14)
    y_smooth = np.interp(x_smooth, x_key, y_key)

    for x, y in zip(x_smooth, y_smooth):
        clear_output(wait=True)
        fig = _draw_trolley_scene(
            ai_data=ai_data,
            selected_tool=selected_tool,
            train_x=float(x),
            train_y=float(y),
            scenario_prompt=scenario_prompt,
            scenario_key=scenario_key,
        )
        display(fig)
        plt.close(fig)
        time.sleep(0.10)

    resolved_scenario_key = scenario_key or _resolve_scenario_key(scenario_prompt or DEFAULT_SCENARIO_PROMPT)
    decision = ai_data[selected_tool]["decision"]
    decision_label = _decision_label(resolved_scenario_key, decision)
    response_text = escape(ai_data[selected_tool]["response"])
    display(
        widgets.HTML(
            value=(
                "<div style='border:1px solid #cfcfcf; border-radius:8px; "
                "padding:12px; margin-top:10px; background:#ffffff; line-height:1.5; "
                "max-width:100%; white-space:normal; overflow-wrap:anywhere; word-break:break-word;'>"
                f"<strong>{escape(selected_tool)}</strong><br><br>"
                f"<strong>Decision:</strong> {escape(decision_label)}<br><br>"
                f"<strong>Response:</strong><br>{response_text}"
                "</div>"
            )
        )
    )


def build_ethics_widget(ai_data=None, scenario_prompt=None, scenario_key=None):
    """
    Build and display the ethics trolley widget UI.

    scenario_prompt: optional string shown at the top of the diagram (use \\n for line breaks).
    If None, uses DEFAULT_SCENARIO_PROMPT (self-preservation scenario).

    Returns (tool_dropdown, run_button, output).
    """
    if scenario_prompt is None:
        scenario_prompt = DEFAULT_SCENARIO_PROMPT
    resolved_scenario_key = scenario_key or _resolve_scenario_key(scenario_prompt)
    if ai_data is None:
        ai_data = _build_ai_data(resolved_scenario_key)

    tool_dropdown = widgets.Dropdown(
        options=list(ai_data.keys()),
        value=list(ai_data.keys())[0],
        description="AI Tool:",
    )

    run_button = widgets.Button(
        description="Run Ethics Simulation",
        button_style="success",
    )

    output = widgets.Output()

    def on_run_clicked(_):
        with output:
            clear_output(wait=True)
            _animate_trolley(
                ai_data=ai_data,
                selected_tool=tool_dropdown.value,
                scenario_prompt=scenario_prompt,
                scenario_key=resolved_scenario_key,
            )

    run_button.on_click(on_run_clicked)
    display(tool_dropdown, run_button, output)

    return tool_dropdown, run_button, output


def build_table(ai_data=None):
    if ai_data is None:
        ai_data = DEFAULT_AI_DATA
    return pd.DataFrame(
        [
            {
                "AI Tool": tool,
                "Decision": info["decision"],
                "Response": info["response"],
            }
            for tool, info in ai_data.items()
        ]
    )
